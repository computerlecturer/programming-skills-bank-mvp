# Supabase v7.2
# NEXT_PUBLIC_SUPABASE_URL: Supabase Project URL, 예: https://xxxxx.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY: Supabase API Keys 화면의 Publishable key 또는 Legacy anon key
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# 서버 전용 키입니다. 브라우저에 노출되는 NEXT_PUBLIC_ 변수로 절대 넣지 마세요.
# v7.2에서는 아직 사용하지 않고, 향후 관리자/웹훅/결제 서버 작업에서만 사용합니다.
SUPABASE_SERVICE_ROLE_KEY=

# Payment Provider: 정식 유료 전환 단계에서 연결
TOSS_CLIENT_KEY=
TOSS_SECRET_KEY=
PORTONE_STORE_ID=
PORTONE_CHANNEL_KEY=
PORTONE_API_SECRET=

# OpenAI AI 문제 변형 기능: 관리자 테스트/정식 기능 연결 단계에서 사용
OPENAI_API_KEY=
